<form class="fabricate-recipe-editor-v2" autocomplete="off">
  <header class="editor-header">
    <h2>{{#if isEdit}}Edit Recipe{{else}}New Recipe{{/if}}</h2>
  </header>

  <section class="editor-scroll editor-layout">
    <div class="editor-main">
      <div class="editor-grid">
        <div class="form-group">
          <label>Recipe Name *</label>
          <input name="name" type="text" value="{{recipe.name}}" required />
        </div>

        <div class="form-group">
          <label>Category</label>
          {{#if availableCategories.length}}
            <select name="category">
              {{#each availableCategories}}
                <option value="{{this}}" {{#if (eq ../recipe.category this)}}selected{{/if}}>{{this}}</option>
              {{/each}}
            </select>
          {{else}}
            <input name="category" type="text" value="{{recipe.category}}" placeholder="No system categories defined yet" />
            <p class="hint">Define categories in Crafting Admin > Systems.</p>
          {{/if}}
        </div>

        <div class="form-group span-2">
          <label>Description</label>
          <textarea name="description" rows="3">{{recipe.description}}</textarea>
        </div>

        <div class="form-group">
          <label>Image</label>
          <input name="img" type="text" value="{{recipe.img}}" />
        </div>

        <div class="form-group span-2">
          <label>Tags (comma separated)</label>
          <input name="tags" type="text" value="{{recipe.tagsText}}" list="fabricate-recipe-tags" />
          {{#if availableTags.length}}
            <p class="hint">Available system tags: {{#each availableTags}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>
          {{else}}
            <p class="hint">No system tags defined yet. Add tags in Crafting Admin > Systems.</p>
          {{/if}}
        </div>
      </div>

      <div class="editor-flags">
        <label><input type="checkbox" name="enabled" {{#if recipe.enabled}}checked{{/if}} /> Enabled</label>
        <label><input type="checkbox" name="isVariable" {{#if recipe.isVariable}}checked{{/if}} /> Variable Output</label>
        <label><input type="checkbox" name="transferEffects" {{#if recipe.transferEffects}}checked{{/if}} /> Transfer Effects</label>
        <label><input type="checkbox" name="requiresAllSets" {{#if recipe.requiresAllSets}}checked{{/if}} /> Require All Ingredient Sets</label>
      </div>

      <hr />

      <section class="editor-block">
        <div class="carousel-header">
          <h3>Ingredient Sets</h3>
          <div class="carousel-controls">
            <button type="button" data-action="prevIngredientSet" title="Previous Set"><i class="fas fa-chevron-left"></i></button>
            <span>Set {{ingredientSetIndex}} / {{ingredientSetCount}}</span>
            <button type="button" data-action="nextIngredientSet" title="Next Set"><i class="fas fa-chevron-right"></i></button>
            <button type="button" data-action="addIngredientSet" title="Add Set"><i class="fas fa-plus"></i></button>
            <button type="button" data-action="removeIngredientSet" title="Remove Set"><i class="fas fa-trash"></i></button>
          </div>
        </div>

        <div class="form-group">
          <label>Set Name</label>
          <input name="ingredientSet.name" type="text" value="{{ingredientSet.name}}" />
          {{#if availableEssences.length}}
            <p class="hint">Available system essences: {{#each availableEssences}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>
          {{else}}
            <p class="hint">No essences defined yet. Add essences in Crafting Admin > Systems.</p>
          {{/if}}
        </div>

        <div class="ingredients-table" data-drop-target="ingredient-new">
          <div class="ingredients-row header">
            <span>Managed Item</span>
            <span>Qty</span>
            <span></span>
          </div>
          {{#each ingredientSet.itemIngredients}}
            <div class="ingredients-row" data-drop-target="ingredient" data-index="{{rowIndex}}">
              <div class="managed-item-cell drop-slot">
                <img src="{{itemImg}}" alt="{{itemName}}" />
                <div class="managed-item-meta">
                  <span>{{itemName}}</span>
                  <div class="inline-actions compact">
                    <button type="button" data-action="clearIngredientSystemItem" data-index="{{rowIndex}}"><i class="fas fa-eraser"></i></button>
                  </div>
                </div>
              </div>
              <input name="itemIngredients.{{rowIndex}}.quantity" type="number" min="1" value="{{quantity}}" />
              <button type="button" data-action="removeIngredientRow" data-index="{{rowIndex}}" title="Remove"><i class="fas fa-trash"></i></button>
            </div>
          {{/each}}
        </div>

        <div class="inline-actions">
          <button type="button" data-action="addIngredientRow"><i class="fas fa-plus"></i> Add Ingredient Row</button>
        </div>

        <div class="alt-ingredients-block">
          <div class="carousel-header small">
            <h4>Tag/Tier Requirements (alternatives to items)</h4>
          </div>
          <div class="ingredients-table alt-table" data-drop-target="tag-new">
            <div class="ingredients-row header alt-header">
              <span>Tag</span>
              <span>Qty</span>
              <span>Tier</span>
              <span></span>
            </div>
            {{#each ingredientSet.tagIngredients}}
              <div class="ingredients-row alt-row">
                <input name="tagIngredients.{{rowIndex}}.tag" value="{{tag}}" placeholder="e.g. armour:leather" list="fabricate-system-tags" />
                <input name="tagIngredients.{{rowIndex}}.quantity" type="number" min="1" value="{{quantity}}" />
                <select name="tagIngredients.{{rowIndex}}.tier">
                  <option value="" {{#unless tier}}selected{{/unless}}>Any</option>
                  {{#each ../availableTiers}}
                    <option value="{{this}}" {{#if (eq ../tier this)}}selected{{/if}}>{{this}}</option>
                  {{/each}}
                </select>
                <button type="button" data-action="removeTagIngredientRow" data-index="{{rowIndex}}" title="Remove"><i class="fas fa-trash"></i></button>
              </div>
            {{/each}}
          </div>
          <div class="inline-actions">
            <button type="button" data-action="addTagIngredientRow"><i class="fas fa-plus"></i> Add Tag Requirement</button>
          </div>
        </div>

        <div class="catalysts-block" data-drop-target="catalyst-new">
          <div class="carousel-header small">
            <h4>Catalysts (for this ingredient set)</h4>
          </div>
          <div class="ingredients-table catalyst-table">
            <div class="ingredients-row header catalyst-header">
              <span>Managed Item</span>
              <span>Name</span>
              <span>Tag</span>
              <span>Required</span>
              <span></span>
            </div>
            {{#each ingredientSet.catalysts}}
              <div class="ingredients-row catalyst-row" data-drop-target="catalyst" data-index="{{rowIndex}}">
                <div class="managed-item-cell drop-slot">
                  <img src="{{itemImg}}" alt="{{itemName}}" />
                  <div class="managed-item-meta">
                    <span>{{itemName}}</span>
                    <div class="inline-actions compact">
                      <button type="button" data-action="clearCatalystSystemItem" data-index="{{rowIndex}}"><i class="fas fa-eraser"></i></button>
                    </div>
                  </div>
                </div>
                <input name="catalysts.{{rowIndex}}.name" value="{{name}}" placeholder="Catalyst name" />
                <input name="catalysts.{{rowIndex}}.tag" value="{{tag}}" placeholder="alternative tag" list="fabricate-system-tags" />
                <label class="tiny-check">
                  <input type="checkbox" name="catalysts.{{rowIndex}}.required" {{#if required}}checked{{/if}} />
                </label>
                <button type="button" data-action="removeCatalystRow" data-index="{{rowIndex}}" title="Remove"><i class="fas fa-trash"></i></button>
              </div>
            {{/each}}
          </div>
          <div class="inline-actions">
            <button type="button" data-action="addCatalystRow"><i class="fas fa-plus"></i> Add Catalyst</button>
          </div>
        </div>
      </section>

      <hr />

      <section class="editor-block">
        <div class="carousel-header">
          <h3>Result Sets</h3>
          <div class="carousel-controls">
            <button type="button" data-action="prevResultSet" title="Previous Result"><i class="fas fa-chevron-left"></i></button>
            <span>Result {{resultIndex}} / {{resultCount}}</span>
            <button type="button" data-action="nextResultSet" title="Next Result"><i class="fas fa-chevron-right"></i></button>
            <button type="button" data-action="addResultSet" title="Add Result"><i class="fas fa-plus"></i></button>
            <button type="button" data-action="removeResultSet" title="Remove Result"><i class="fas fa-trash"></i></button>
          </div>
        </div>

        <div class="result-selected-item" data-drop-target="result">
          <img src="{{resultSet.itemImg}}" alt="{{resultSet.itemName}}" />
          <div class="result-selected-meta">
            <h4>{{resultSet.itemName}}</h4>
            <div class="inline-actions compact">
              <button type="button" data-action="clearResultSystemItem"><i class="fas fa-eraser"></i></button>
            </div>
          </div>
        </div>

        <div class="editor-grid">
          <div class="form-group">
            <label>Quantity</label>
            <input name="result.quantity" type="number" min="1" value="{{resultSet.quantity}}" />
          </div>
          <div class="form-group span-2">
            <label>Property Formulas (JSON)</label>
            <textarea name="result.propertyFormulas" rows="3">{{json resultSet.propertyFormulas}}</textarea>
          </div>
        </div>
      </section>
    </div>

    <aside class="item-picker-panel">
      <h3>System Items</h3>
      <input
        type="text"
        name="pickerSearch"
        placeholder="Search managed items..."
        value="{{pickerSearch}}"
        data-action="pickerSearch"
      />

      <div class="picker-grid">
        {{#each pickerItems}}
          <button type="button" class="picker-card" data-item-id="{{id}}" draggable="true">
            <img src="{{img}}" alt="{{name}}" />
            <span>{{name}}</span>
            {{#if sourceUuid}}
              <code>{{sourceUuid}}</code>
            {{/if}}
          </button>
        {{else}}
          <div class="fabricate-empty">
            <i class="fas fa-inbox"></i>
            <p>No managed items in this system.</p>
            <p class="hint">Add items in the Crafting Admin Items tab.</p>
          </div>
        {{/each}}
      </div>
      <datalist id="fabricate-system-tags">
        {{#each availableTags}}
          <option value="{{this}}">
        {{/each}}
      </datalist>
      <datalist id="fabricate-recipe-tags">
        {{#each availableTags}}
          <option value="{{this}}">
        {{/each}}
      </datalist>
    </aside>
  </section>

  <footer class="editor-footer">
    <button type="button" class="btn-cancel" data-action="cancel"><i class="fas fa-times"></i> Cancel</button>
    <button type="submit" class="btn-save" data-action="saveRecipe"><i class="fas fa-save"></i> Save Recipe</button>
  </footer>
</form>
