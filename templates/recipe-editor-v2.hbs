<form class="fabricate-recipe-editor-v2" autocomplete="off">
  <header class="editor-header">
    <h2>{{#if isEdit}}Edit Recipe{{else}}New Recipe{{/if}}</h2>
  </header>

  <section class="editor-scroll">
    <div class="editor-grid">
      <div class="form-group">
        <label>Recipe Name *</label>
        <input name="name" type="text" value="{{recipe.name}}" required />
      </div>

      <div class="form-group">
        <label>Category</label>
        <input name="category" type="text" value="{{recipe.category}}" list="fabricate-category-list" />
        <datalist id="fabricate-category-list">
          {{#each availableCategories}}
            <option value="{{this}}">
          {{/each}}
        </datalist>
      </div>

      <div class="form-group span-2">
        <label>Description</label>
        <textarea name="description" rows="3">{{recipe.description}}</textarea>
      </div>

      <div class="form-group">
        <label>System</label>
        <select name="system">
          <option value="all" {{#if (eq recipe.system "all")}}selected{{/if}}>All</option>
          <option value="dnd5e" {{#if (eq recipe.system "dnd5e")}}selected{{/if}}>D&D 5e</option>
          <option value="pf2e" {{#if (eq recipe.system "pf2e")}}selected{{/if}}>PF2e</option>
          <option value="other" {{#if (eq recipe.system "other")}}selected{{/if}}>Other</option>
        </select>
      </div>

      <div class="form-group">
        <label>Image</label>
        <input name="img" type="text" value="{{recipe.img}}" />
      </div>

      <div class="form-group span-2">
        <label>Tags (comma separated)</label>
        <input name="tags" type="text" value="{{recipe.tagsText}}" />
      </div>
    </div>

    <div class="editor-flags">
      <label><input type="checkbox" name="enabled" {{#if recipe.enabled}}checked{{/if}} /> Enabled</label>
      <label><input type="checkbox" name="isVariable" {{#if recipe.isVariable}}checked{{/if}} /> Variable Output</label>
      <label><input type="checkbox" name="transferEffects" {{#if recipe.transferEffects}}checked{{/if}} /> Transfer Effects</label>
      <label><input type="checkbox" name="requiresAllSets" {{#if recipe.requiresAllSets}}checked{{/if}} /> Require All Ingredient Sets</label>
    </div>

    <hr />

    <section class="editor-block">
      <div class="carousel-header">
        <h3>Ingredient Sets</h3>
        <div class="carousel-controls">
          <button type="button" data-action="prevIngredientSet" title="Previous Set"><i class="fas fa-chevron-left"></i></button>
          <span>Set {{ingredientSetIndex}} / {{ingredientSetCount}}</span>
          <button type="button" data-action="nextIngredientSet" title="Next Set"><i class="fas fa-chevron-right"></i></button>
          <button type="button" data-action="addIngredientSet" title="Add Set"><i class="fas fa-plus"></i></button>
          <button type="button" data-action="removeIngredientSet" title="Remove Set"><i class="fas fa-trash"></i></button>
        </div>
      </div>

      <div class="form-group">
        <label>Set Name</label>
        <input name="ingredientSet.name" type="text" value="{{ingredientSet.name}}" />
      </div>

      <div class="drop-zone" data-drop-zone="ingredient">
        <i class="fas fa-hand-pointer"></i>
        Drag and drop Item documents here to add components.
      </div>

      <div class="ingredients-table">
        <div class="ingredients-row header">
          <span>Item UUID</span>
          <span>Tag</span>
          <span>Qty</span>
          <span>Tier</span>
          <span>Extract</span>
          <span>Filter</span>
          <span></span>
        </div>
        {{#each ingredientSet.ingredients}}
          <div class="ingredients-row">
            <input name="ingredients.{{@index}}.itemUuid" value="{{itemUuid}}" placeholder="Item.x" />
            <input name="ingredients.{{@index}}.tag" value="{{tag}}" placeholder="metal:iron" />
            <input name="ingredients.{{@index}}.quantity" type="number" min="1" value="{{quantity}}" />
            <select name="ingredients.{{@index}}.tier">
              <option value="" {{#unless tier}}selected{{/unless}}>Any</option>
              <option value="common" {{#if (eq tier "common")}}selected{{/if}}>Common</option>
              <option value="uncommon" {{#if (eq tier "uncommon")}}selected{{/if}}>Uncommon</option>
              <option value="rare" {{#if (eq tier "rare")}}selected{{/if}}>Rare</option>
              <option value="legendary" {{#if (eq tier "legendary")}}selected{{/if}}>Legendary</option>
            </select>
            <label class="tiny-check">
              <input name="ingredients.{{@index}}.extractEffects" type="checkbox" {{#if extractEffects}}checked{{/if}} />
            </label>
            <input name="ingredients.{{@index}}.effectFilter" value="{{effectFilter}}" placeholder="poison|fire" />
            <button type="button" data-action="removeIngredientRow" data-index="{{@index}}" title="Remove"><i class="fas fa-trash"></i></button>
          </div>
        {{/each}}
      </div>

      <div class="inline-actions">
        <button type="button" data-action="addIngredientRow"><i class="fas fa-plus"></i> Add Ingredient Row</button>
      </div>
    </section>

    <hr />

    <section class="editor-block">
      <div class="carousel-header">
        <h3>Result Sets</h3>
        <div class="carousel-controls">
          <button type="button" data-action="prevResultSet" title="Previous Result"><i class="fas fa-chevron-left"></i></button>
          <span>Result {{resultIndex}} / {{resultCount}}</span>
          <button type="button" data-action="nextResultSet" title="Next Result"><i class="fas fa-chevron-right"></i></button>
          <button type="button" data-action="addResultSet" title="Add Result"><i class="fas fa-plus"></i></button>
          <button type="button" data-action="removeResultSet" title="Remove Result"><i class="fas fa-trash"></i></button>
        </div>
      </div>

      <div class="drop-zone" data-drop-zone="result">
        <i class="fas fa-gift"></i>
        Drag and drop an Item document here to set the current result.
      </div>

      <div class="editor-grid">
        <div class="form-group">
          <label>Result Item UUID *</label>
          <input name="result.itemUuid" value="{{resultSet.itemUuid}}" required />
        </div>
        <div class="form-group">
          <label>Quantity</label>
          <input name="result.quantity" type="number" min="1" value="{{resultSet.quantity}}" />
        </div>
        <div class="form-group span-2">
          <label>Property Formulas (JSON)</label>
          <textarea name="result.propertyFormulas" rows="3">{{json resultSet.propertyFormulas}}</textarea>
        </div>
      </div>
    </section>
  </section>

  <footer class="editor-footer">
    <button type="button" class="btn-cancel" data-action="cancel"><i class="fas fa-times"></i> Cancel</button>
    <button type="submit" class="btn-save" data-action="saveRecipe"><i class="fas fa-save"></i> Save Recipe</button>
  </footer>
</form>

