<form class="fabricate-recipe-editor-v2" autocomplete="off">
  <header class="editor-header">
    <h2>{{#if isEdit}}Edit Recipe{{else}}New Recipe{{/if}}</h2>
  </header>

  {{#if validationErrors.length}}
    <div class="validation-banner">
      <strong>Fix before saving:</strong>
      <ul>
        {{#each validationErrors}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
    </div>
  {{/if}}

  <section class="editor-scroll editor-layout">
    <div class="editor-main">
      <div class="editor-grid">
        <div class="form-group">
          <label>Recipe Name *</label>
          <input name="name" type="text" value="{{recipe.name}}" required />
        </div>

        {{#if showCategories}}
          <div class="form-group">
            <label>Category</label>
            {{#if availableCategories.length}}
              <select name="category">
                {{#each availableCategories}}
                  <option value="{{this}}" {{#if (eq ../recipe.category this)}}selected{{/if}}>{{this}}</option>
                {{/each}}
              </select>
            {{else}}
              <input name="category" type="text" value="{{recipe.category}}" placeholder="No system categories defined yet" />
              <p class="hint">Define categories in Crafting Admin > Systems.</p>
            {{/if}}
          </div>
        {{/if}}

        <div class="form-group span-2">
          <label>Description</label>
          <textarea name="description" rows="3">{{recipe.description}}</textarea>
        </div>

        <div class="form-group">
          <label>Image</label>
          <input name="img" type="text" value="{{recipe.img}}" />
        </div>

      </div>

      <div class="editor-flags">
        <label><input type="checkbox" name="enabled" {{#if recipe.enabled}}checked{{/if}} /> Enabled</label>
        {{#if showComplexRecipes}}
          <label><input type="checkbox" name="isVariable" {{#if recipe.isVariable}}checked{{/if}} /> Variable Output</label>
        {{/if}}
        <label><input type="checkbox" name="transferEffects" {{#if recipe.transferEffects}}checked{{/if}} /> Transfer Effects</label>
        {{#if showComplexRecipes}}
          <label><input type="checkbox" name="requiresAllSets" {{#if recipe.requiresAllSets}}checked{{/if}} /> Require All Ingredient Sets</label>
        {{/if}}
      </div>

      <hr />

      <section class="editor-block">
        <div class="carousel-header">
          <h3>Ingredient Sets</h3>
          <div class="carousel-controls">
            {{#if showComplexRecipes}}
              <button type="button" data-action="prevIngredientSet" title="Previous Set"><i class="fas fa-chevron-left"></i></button>
            {{/if}}
            <span>Set {{ingredientSetIndex}} / {{ingredientSetCount}}</span>
            {{#if showComplexRecipes}}
              <button type="button" data-action="nextIngredientSet" title="Next Set"><i class="fas fa-chevron-right"></i></button>
              <button type="button" data-action="addIngredientSet" title="Add Set"><i class="fas fa-plus"></i></button>
              <button type="button" data-action="removeIngredientSet" title="Remove Set"><i class="fas fa-trash"></i></button>
            {{/if}}
          </div>
        </div>

        <div class="form-group">
          <label>Set Name</label>
          <input name="ingredientSet.name" type="text" value="{{ingredientSet.name}}" />
          {{#if showEssences}}
            {{#if availableEssences.length}}
              <p class="hint">Available system essences: {{#each availableEssences}}{{name}}{{#unless @last}}, {{/unless}}{{/each}}</p>
            {{else}}
              <p class="hint">No essences defined yet. Add essences in Crafting Admin > Systems.</p>
            {{/if}}
          {{/if}}
        </div>

        <div class="ingredients-table" data-drop-target="ingredient-new">
          <div class="ingredients-row header">
            <span>Managed Item</span>
            <span>Qty</span>
            <span></span>
          </div>
          {{#if ingredientSet.itemIngredients.length}}
            {{#each ingredientSet.itemIngredients}}
              <div class="ingredients-row" data-drop-target="ingredient" data-index="{{rowIndex}}">
                <div class="managed-item-cell drop-slot">
                  <img src="{{itemImg}}" alt="{{itemName}}" />
                  <div class="managed-item-meta">
                    <span>{{itemName}}</span>
                  </div>
                </div>
                <input name="itemIngredients.{{rowIndex}}.quantity" type="number" min="1" value="{{quantity}}" />
                <button type="button" data-action="removeIngredientRow" data-index="{{rowIndex}}" title="Remove"><i class="fas fa-trash"></i></button>
              </div>
            {{/each}}
          {{else}}
            <div class="ingredients-empty">
              <p>Drop managed items here to add ingredients.</p>
            </div>
          {{/if}}
        </div>

        <div class="catalysts-block" data-drop-target="catalyst-new">
          <div class="carousel-header small">
            <h4>Catalysts (for this ingredient set)</h4>
          </div>
          <div class="ingredients-table catalyst-table">
            <div class="ingredients-row header catalyst-header">
              <span>Managed Item</span>
              <span>Degrades</span>
              <span>Max Uses</span>
              <span></span>
            </div>
            {{#if ingredientSet.catalysts.length}}
              {{#each ingredientSet.catalysts}}
                <div class="ingredients-row catalyst-row" data-drop-target="catalyst" data-index="{{rowIndex}}">
                  <div class="managed-item-cell drop-slot">
                  <img src="{{itemImg}}" alt="{{itemName}}" />
                  <div class="managed-item-meta">
                    <span>{{itemName}}</span>
                  </div>
                </div>
                  <label class="tiny-check">
                    <input type="checkbox" name="catalysts.{{rowIndex}}.degradesOnUse" {{#if degradesOnUse}}checked{{/if}} />
                  </label>
                  <input name="catalysts.{{rowIndex}}.maxUses" type="number" min="1" value="{{maxUses}}" placeholder="Unlimited" />
                  <button type="button" data-action="removeCatalystRow" data-index="{{rowIndex}}" title="Remove"><i class="fas fa-trash"></i></button>
                </div>
              {{/each}}
            {{else}}
              <div class="ingredients-empty">
                <p>Drop managed items here to add catalysts.</p>
              </div>
            {{/if}}
          </div>
        </div>

        {{#if showComplexRecipes}}
        {{#if recipe.isVariable}}
          <div class="result-mapping-block">
            <div class="carousel-header small">
              <h4>Result Group Mapping (for this ingredient set)</h4>
            </div>
            {{#if resultOptions.length}}
              <div class="mapping-grid">
                {{#each resultOptions}}
                  <label class="mapping-card">
                    <input type="checkbox" name="resultMapping.{{id}}" {{#if selected}}checked{{/if}} />
                    <img src="{{img}}" alt="{{name}}" />
                    <span>{{name}}</span>
                  </label>
                {{/each}}
              </div>
            {{else}}
              <p class="hint">Add result groups first, then map them to ingredient sets.</p>
            {{/if}}
          </div>
        {{/if}}
        {{/if}}

        {{#if showComplexRecipes}}
        {{#if showCraftingChecks}}
        {{#if showOutcomeRouting}}
          {{#if outcomeRoutingRows.length}}
          <div class="result-mapping-block">
            <div class="carousel-header small">
              <h4>Outcome Routing</h4>
            </div>
            <p class="hint">Route check outcomes to a specific result group. Leave blank to use default recipe output.</p>
            <div class="editor-grid">
              {{#each outcomeRoutingRows}}
                <div class="form-group">
                  <label>{{outcome}}</label>
                  <select name="outcomeRouting.{{outcome}}">
                    <option value="">Default output</option>
                    {{#each options}}
                      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                    {{/each}}
                  </select>
                </div>
              {{/each}}
            </div>
          </div>
          {{/if}}
        {{/if}}
        {{/if}}
        {{/if}}
      </section>

      <hr />

      <section class="editor-block">
        <div class="carousel-header">
          <h3>Result Groups</h3>
          <div class="carousel-controls">
            {{#if showComplexRecipes}}
              <button type="button" data-action="prevResultSet" title="Previous Group"><i class="fas fa-chevron-left"></i></button>
            {{/if}}
            <span>Group {{resultGroupIndex}} / {{resultGroupCount}}</span>
            {{#if showComplexRecipes}}
              <button type="button" data-action="nextResultSet" title="Next Group"><i class="fas fa-chevron-right"></i></button>
              <button type="button" data-action="addResultSet" title="Add Group"><i class="fas fa-plus"></i></button>
              <button type="button" data-action="removeResultSet" title="Remove Group"><i class="fas fa-trash"></i></button>
            {{/if}}
          </div>
        </div>

        {{#if resultGroup}}
          <div class="form-group">
            <label>Group Name</label>
            <input name="resultGroup.name" type="text" value="{{resultGroup.name}}" />
          </div>

          <div class="ingredients-table result-table" {{#if showComplexRecipes}}data-drop-target="result-row-new"{{/if}}>
            <div class="ingredients-row header">
              <span>Managed Item</span>
              <span>Qty</span>
              <span></span>
            </div>
            {{#if resultGroup.results.length}}
              {{#each resultGroup.results}}
                <div class="ingredients-row" data-drop-target="result-row" data-index="{{rowIndex}}">
                  <div class="managed-item-cell drop-slot">
                    <img src="{{itemImg}}" alt="{{itemName}}" />
                    <div class="managed-item-meta">
                      <span>{{itemName}}</span>
                    </div>
                  </div>
                  <input name="resultRows.{{rowIndex}}.quantity" type="number" min="1" value="{{quantity}}" />
                  {{#if ../showComplexRecipes}}
                    <button type="button" data-action="removeResultRow" data-index="{{rowIndex}}" title="Remove"><i class="fas fa-trash"></i></button>
                  {{else}}
                    <span></span>
                  {{/if}}
                </div>
                {{#if ../showPropertyMacros}}
                  <div class="editor-grid result-row-macro">
                    <div class="form-group span-2">
                      <label>Property Macro</label>
                      <select name="resultRows.{{rowIndex}}.propertyMacroUuid">
                        <option value="">No property macro</option>
                        {{#each ../../availablePropertyMacros}}
                          <option value="{{uuid}}" {{#if (eq ../propertyMacroUuid uuid)}}selected{{/if}}>{{name}}</option>
                        {{/each}}
                      </select>
                    </div>
                  </div>
                {{/if}}
              {{/each}}
            {{else}}
              <div class="ingredients-empty">
                <p>Drop managed items here to add results.</p>
              </div>
            {{/if}}
          </div>
          {{#if showComplexRecipes}}
            <div class="inline-actions">
              <button type="button" data-action="addResultRow"><i class="fas fa-plus"></i> Add Result</button>
            </div>
          {{/if}}
        {{else}}
          <div class="fabricate-empty" data-drop-target="result-row-new">
            <i class="fas fa-gift"></i>
            <p>Drop an item here to add a result.</p>
          </div>
        {{/if}}
      </section>
    </div>

    <aside class="item-picker-panel">
      <h3>System Items</h3>
      <input
        type="text"
        name="pickerSearch"
        placeholder="Search managed items..."
        value="{{pickerSearch}}"
        data-action="pickerSearch"
      />

      <div class="picker-grid">
        {{#each pickerItems}}
          <button type="button" class="picker-card" data-item-id="{{id}}" draggable="true">
            <img src="{{img}}" alt="{{name}}" />
            <span>{{name}}</span>
            {{#if sourceUuid}}
              <code>{{sourceUuid}}</code>
            {{/if}}
          </button>
        {{else}}
          <div class="fabricate-empty">
            <i class="fas fa-inbox"></i>
            <p>No managed items in this system.</p>
            <p class="hint">Add items in the Crafting Admin Items tab.</p>
          </div>
        {{/each}}
      </div>
    </aside>
  </section>

  <footer class="editor-footer">
    <button type="button" class="btn-cancel" data-action="cancel"><i class="fas fa-times"></i> Cancel</button>
    <button type="submit" class="btn-save" data-action="saveRecipe"><i class="fas fa-save"></i> Save Recipe</button>
  </footer>
</form>
