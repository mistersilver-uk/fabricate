<div class="fabricate-crafting-app">
  <!-- Actor Selection Section -->
  <section class="actor-selection-section">
    <div class="crafting-actor-selector">
      <label for="crafting-actor">Craft with:</label>
      <select id="crafting-actor" name="craftingActor">
        {{#each availableActors}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>
            {{name}}{{#if isAssignedCharacter}} *{{/if}}
          </option>
        {{/each}}
      </select>
      <p class="hint">Results will be added to this actor's inventory</p>
    </div>

    <div class="component-sources-selector">
      <label>Using components from:</label>
      {{#if ownedActors.length}}
        <div class="source-actor-list">
          {{#each ownedActors}}
            <label class="source-actor-checkbox">
              <input
                type="checkbox"
                value="{{id}}"
                {{#if selected}}checked{{/if}}
                data-action="toggleSourceActor"
              />
              <span class="actor-name">{{name}}</span>
            </label>
          {{/each}}
        </div>
      {{else}}
        <p class="no-actors-warning">
          <i class="fas fa-exclamation-triangle"></i>
          No owned actors available for component sources.
        </p>
      {{/if}}
    </div>
  </section>

  {{#if hasCraftingActor}}
    <section class="run-summary-section">
      <div class="run-columns">
        <div class="run-column">
          <h4>In Progress</h4>
          {{#if activeRuns.length}}
            <ul class="run-list">
              {{#each activeRuns}}
                <li class="run-row">
                  <strong>{{recipeName}}</strong>
                  <span class="badge">{{statusLabel}}</span>
                  {{#if stepLabel}}<span class="hint">{{stepLabel}}</span>{{/if}}
                  <span class="run-row-actions">
                    {{#if canContinue}}
                      <button type="button" class="details-btn" data-action="craft" data-recipe-id="{{recipeId}}" data-run-id="{{id}}" title="Continue this run">
                        <i class="fas fa-play"></i>
                      </button>
                    {{/if}}
                    <button type="button" class="details-btn" data-action="showRunDetails" data-run-id="{{id}}" data-run-scope="active" title="Run details">
                      <i class="fas fa-list"></i>
                    </button>
                    <button type="button" class="details-btn" data-action="restartRun" data-recipe-id="{{recipeId}}" data-run-id="{{id}}" title="Restart run">
                      <i class="fas fa-rotate-left"></i>
                    </button>
                    {{#if canCancel}}
                      <button type="button" class="details-btn" data-action="cancelRun" data-run-id="{{id}}" title="Cancel run">
                        <i class="fas fa-stop"></i>
                      </button>
                    {{/if}}
                  </span>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="hint">No active crafting runs for this actor.</p>
          {{/if}}
        </div>
        <div class="run-column">
          <h4>Recent History</h4>
          {{#if runHistory.length}}
            <ul class="run-list">
              {{#each runHistory}}
                <li class="run-row">
                  <strong>{{recipeName}}</strong>
                  <span class="badge">{{statusLabel}}</span>
                  <span class="run-row-actions">
                    <button type="button" class="details-btn" data-action="showRunDetails" data-run-id="{{id}}" data-run-scope="history" title="Run details">
                      <i class="fas fa-list"></i>
                    </button>
                  </span>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="hint">No recent crafting history.</p>
          {{/if}}
        </div>
      </div>
    </section>
  {{/if}}

  <!-- Search and Filters Header -->
  <header class="fabricate-header">
    <div class="fabricate-search">
      <input
        type="text"
        name="search"
        placeholder="Search recipes..."
        value="{{search}}"
        data-action="search"
      />
      <i class="fas fa-search"></i>
    </div>

    <div class="fabricate-filters">
      <button
        type="button"
        class="fabricate-filter-btn {{#if showOnlyAvailable}}active{{/if}}"
        data-action="toggleAvailable"
        title="Show only craftable recipes"
      >
        <i class="fas fa-check-circle"></i>
        Craftable Only
      </button>

      <select name="category">
        <option value="">All Categories</option>
        {{#each categories}}
        <option value="{{this}}" {{#if (eq ../selectedCategory this)}}selected{{/if}}>
          {{this}}
        </option>
        {{/each}}
      </select>
    </div>
  </header>

  <!-- Recipe List -->
  <div class="fabricate-recipe-list">
    {{#unless hasComponentSources}}
      <div class="fabricate-empty">
        <i class="fas fa-info-circle"></i>
        <p>Select at least one component source actor to see available recipes.</p>
      </div>
    {{else}}

      <!-- Favourites quick-access section -->
      {{#if favouriteRecipes.length}}
        <div class="fabricate-quick-section favourites-section">
          <h4><i class="fas fa-star"></i> Favourites</h4>
          <div class="quick-recipe-list">
            {{#each favouriteRecipes}}
              <div class="quick-recipe-item" data-recipe-id="{{id}}">
                <img src="{{img}}" alt="{{name}}" class="quick-recipe-icon" />
                <span class="quick-recipe-name">{{name}}</span>
                <span class="badge">{{statusLabel}}</span>
                {{#if allowCraftAction}}
                  <button type="button" class="craft-btn" data-action="craft" data-recipe-id="{{id}}" data-run-id="{{activeRunId}}">
                    <i class="fas fa-hammer"></i> {{craftButtonLabel}}
                  </button>
                {{/if}}
                <button type="button" class="details-btn favourite-btn is-favourite" data-action="toggleFavourite" data-recipe-id="{{id}}" title="Remove from favourites">
                  <i class="fas fa-star"></i>
                </button>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      <!-- Recently Crafted quick-access section -->
      {{#if recentRecipes.length}}
        <div class="fabricate-quick-section recent-section">
          <h4><i class="fas fa-clock"></i> Recently Crafted</h4>
          <div class="quick-recipe-list">
            {{#each recentRecipes}}
              <div class="quick-recipe-item" data-recipe-id="{{id}}">
                <img src="{{img}}" alt="{{name}}" class="quick-recipe-icon" />
                <span class="quick-recipe-name">{{name}}</span>
                <span class="badge">{{statusLabel}}</span>
                {{#if allowCraftAction}}
                  <button type="button" class="craft-btn" data-action="craft" data-recipe-id="{{id}}" data-run-id="{{activeRunId}}">
                    <i class="fas fa-hammer"></i> {{craftButtonLabel}}
                  </button>
                {{/if}}
                <button type="button" class="details-btn" data-action="showDetails" data-recipe-id="{{id}}" title="Show recipe details">
                  <i class="fas fa-info-circle"></i>
                </button>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{#if recipes.length}}
        {{#each recipes}}
          <article class="fabricate-recipe-item {{#if canCraft}}can-craft{{else}}cannot-craft{{/if}}" data-recipe-id="{{id}}">
            <div class="recipe-icon">
              <img src="{{img}}" alt="{{name}}" />
            </div>

            <div class="recipe-info">
              <h3 class="recipe-name">
                {{name}}
                <span class="badge">{{statusLabel}}</span>
                {{#if hasMultipleSets}}
                  <span class="badge">Multiple options</span>
                {{/if}}
                {{#if hasMultipleActiveRuns}}
                  <span class="badge">{{activeRunCount}} active runs</span>
                {{/if}}
              </h3>
              <p class="recipe-description">{{description}}</p>
              {{#if activeRunStepLabel}}
                <p class="hint">Current run: {{activeRunStepLabel}}</p>
              {{/if}}

              <div class="recipe-requirements">
                {{#if ingredients.length}}
                <div class="ingredient-list">
                  <strong>Ingredients:</strong>
                  {{#each ingredients}}
                    <span class="ingredient-badge {{#if satisfied}}satisfied{{else}}unsatisfied{{/if}}">
                      {{description}}
                      <span class="quantity">({{have}}/{{need}})</span>
                    </span>
                  {{/each}}
                </div>
                {{/if}}

                {{#if essences.length}}
                <div class="essence-list">
                  <strong>Essences:</strong>
                  {{#each essences}}
                    <span class="essence-badge {{#if satisfied}}satisfied{{else}}unsatisfied{{/if}}">
                      {{type}}: {{need}}
                    </span>
                  {{/each}}
                </div>
                {{/if}}

                {{#if catalysts.length}}
                <div class="catalyst-list">
                  <strong>Requires:</strong>
                  {{#each catalysts}}
                    <span class="catalyst-badge {{#if available}}have{{else}}need{{/if}}">
                      <i class="fas fa-tools"></i> {{name}}
                    </span>
                  {{/each}}
                </div>
                {{/if}}
              </div>

              <div class="recipe-result">
                <i class="fas fa-arrow-right"></i>
                <strong>{{resultDescription}}</strong>
              </div>
            </div>

            <div class="recipe-actions">
              {{#if allowCraftAction}}
                <button
                  type="button"
                  class="craft-btn"
                  data-action="craft"
                  data-recipe-id="{{id}}"
                  data-run-id="{{activeRunId}}"
                  title="Craft this recipe"
                >
                  <i class="fas fa-hammer"></i>
                  {{craftButtonLabel}}
                </button>
              {{else}}
                {{#if activeRunId}}
                  <button
                    type="button"
                    class="craft-btn disabled"
                    disabled
                    title="{{statusLabel}}"
                  >
                    <i class="fas fa-hourglass-half"></i>
                    Waiting
                  </button>
                {{else}}
                  <button
                    type="button"
                    class="craft-btn disabled"
                    disabled
                    title="{{statusLabel}}"
                  >
                    <i class="fas fa-ban"></i>
                    Cannot Craft
                  </button>
                {{/if}}
                {{#if canLearn}}
                  <button
                    type="button"
                    class="craft-btn"
                    data-action="learnRecipe"
                    data-recipe-id="{{id}}"
                    title="Learn this recipe"
                  >
                    <i class="fas fa-book-open"></i>
                    Learn
                  </button>
                {{/if}}
              {{/if}}

              <button
                type="button"
                class="details-btn favourite-btn {{#if isFavourite}}is-favourite{{/if}}"
                data-action="toggleFavourite"
                data-recipe-id="{{id}}"
                title="{{#if isFavourite}}Remove from favourites{{else}}Add to favourites{{/if}}"
              >
                <i class="fas fa-star"></i>
              </button>

              <button
                type="button"
                class="details-btn"
                data-action="showDetails"
                data-recipe-id="{{id}}"
                title="Show recipe details"
              >
                <i class="fas fa-info-circle"></i>
              </button>
              {{#if activeRunId}}
                <button
                  type="button"
                  class="details-btn"
                  data-action="restartRun"
                  data-recipe-id="{{id}}"
                  data-run-id="{{activeRunId}}"
                  title="Restart run from step 1"
                >
                  <i class="fas fa-rotate-left"></i>
                </button>
              {{/if}}
            </div>
          </article>
        {{/each}}
      {{else}}
        <div class="fabricate-empty">
          <i class="fas fa-inbox"></i>
          <p>No recipes found.</p>
          {{#if search}}
            <p class="hint">Try adjusting your search or filters.</p>
          {{else}}
            <p class="hint">The GM needs to create some recipes first.</p>
          {{/if}}
        </div>
      {{/if}}
    {{/unless}}
  </div>

  {{#if showPagination}}
  <footer class="fabricate-footer">
    <div class="pagination">
      <span>Showing {{startIndex}}-{{endIndex}} of {{totalRecipes}} recipes</span>
    </div>
  </footer>
  {{/if}}
</div>
