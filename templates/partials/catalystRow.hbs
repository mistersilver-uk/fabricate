<div class="catalyst-row" data-index="{{@index}}">
  <div class="row-handle">
    <i class="fas fa-grip-vertical"></i>
  </div>

  <div class="row-content">
    <div class="form-row">
      <div class="form-group flex-2">
        <label>Catalyst Name</label>
        <input
          type="text"
          name="catalysts.{{@index}}.name"
          value="{{name}}"
          placeholder="e.g., Blacksmith Forge"
          data-dtype="String"
        />
      </div>

      <div class="form-group flex-2">
        <label>Item UUID or Tag</label>
        <input
          type="text"
          name="catalysts.{{@index}}.itemUuid"
          value="{{itemUuid}}"
          placeholder="Item.xxx or tag:forge"
          data-dtype="String"
        />
      </div>
    </div>

    <div class="form-row checkbox-row">
      <label>
        <input
          type="checkbox"
          name="catalysts.{{@index}}.required"
          {{#if required}}checked{{/if}}
        />
        Required
      </label>

      <label>
        <input
          type="checkbox"
          name="catalysts.{{@index}}.mustBeEquipped"
          {{#if mustBeEquipped}}checked{{/if}}
        />
        Must Be Equipped
      </label>

      <label>
        <input
          type="checkbox"
          name="catalysts.{{@index}}.degradesOnUse"
          {{#if degradesOnUse}}checked{{/if}}
        />
        Degrades on Use
      </label>

      <label>
        <input
          type="checkbox"
          name="catalysts.{{@index}}.qualityBonus"
          {{#if qualityBonus}}checked{{/if}}
        />
        Quality Affects Output
      </label>
    </div>

    {{#if degradesOnUse}}
    <div class="form-row">
      <div class="form-group">
        <label>Degradation Amount</label>
        <input
          type="number"
          name="catalysts.{{@index}}.degradeAmount"
          value="{{degradeAmount}}"
          min="0"
          step="0.1"
          data-dtype="Number"
        />
      </div>

      <div class="form-group">
        <label>Durability Attribute Path</label>
        <input
          type="text"
          name="catalysts.{{@index}}.durabilityAttribute"
          value="{{durabilityAttribute}}"
          placeholder="system.durability"
        />
      </div>
    </div>
    {{/if}}
  </div>

  <div class="row-actions">
    <button type="button" class="btn-icon" data-action="removeCatalyst" data-index="{{@index}}" title="Remove">
      <i class="fas fa-trash"></i>
    </button>
  </div>
</div>
