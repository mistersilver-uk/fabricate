<div class="ingredient-row" data-index="{{@index}}">
  <div class="row-handle">
    <i class="fas fa-grip-vertical"></i>
  </div>

  <div class="row-content">
    <div class="form-row">
      <div class="form-group flex-2">
        <label>Item UUID or Tag</label>
        <input
          type="text"
          name="ingredients.{{@index}}.itemUuid"
          value="{{itemUuid}}"
          placeholder="Item.xxx or tag:metal"
          data-dtype="String"
        />
      </div>

      <div class="form-group flex-1">
        <label>Quantity</label>
        <input
          type="number"
          name="ingredients.{{@index}}.quantity"
          value="{{quantity}}"
          min="1"
          data-dtype="Number"
        />
      </div>

      <div class="form-group flex-1">
        <label>Tier</label>
        <select name="ingredients.{{@index}}.tier">
          <option value="">Any</option>
          <option value="common" {{#if (eq tier "common")}}selected{{/if}}>Common</option>
          <option value="uncommon" {{#if (eq tier "uncommon")}}selected{{/if}}>Uncommon</option>
          <option value="rare" {{#if (eq tier "rare")}}selected{{/if}}>Rare</option>
          <option value="legendary" {{#if (eq tier "legendary")}}selected{{/if}}>Legendary</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group checkbox-group">
        <label>
          <input
            type="checkbox"
            name="ingredients.{{@index}}.extractEffects"
            {{#if extractEffects}}checked{{/if}}
          />
          Extract Active Effects
        </label>

        {{#if extractEffects}}
        <input
          type="text"
          name="ingredients.{{@index}}.effectFilter"
          value="{{effectFilter}}"
          placeholder="Optional: filter regex"
          class="effect-filter"
        />
        {{/if}}
      </div>
    </div>
  </div>

  <div class="row-actions">
    <button type="button" class="btn-icon" data-action="removeIngredient" data-index="{{@index}}" title="Remove">
      <i class="fas fa-trash"></i>
    </button>
  </div>
</div>
