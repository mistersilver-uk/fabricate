<div class="fabricate-admin">
  <header class="admin-header">
    <nav class="admin-tabs">
      <button type="button" class="{{#if (eq activeTab 'systems')}}active{{/if}}" data-action="setTab" data-tab="systems">
        <i class="fas fa-layer-group"></i> Systems
      </button>
      <button type="button" class="{{#if (eq activeTab 'items')}}active{{/if}}" data-action="setTab" data-tab="items">
        <i class="fas fa-boxes"></i> Items
      </button>
      <button type="button" class="{{#if (eq activeTab 'recipes')}}active{{/if}}" data-action="setTab" data-tab="recipes">
        <i class="fas fa-scroll"></i> Recipes
      </button>
      <button type="button" class="{{#if (eq activeTab 'rules')}}active{{/if}}" data-action="setTab" data-tab="rules">
        <i class="fas fa-sliders-h"></i> Rules
      </button>
    </nav>

    <div class="admin-system-name">
      {{#if hasSystem}}
        <span>Selected: <strong>{{selectedSystemName}}</strong></span>
      {{else}}
        <span>No crafting systems yet</span>
      {{/if}}
    </div>
  </header>

  <div class="admin-body">
    <aside class="admin-sidebar">
      <div class="admin-sidebar-header">
        <h3>Crafting Systems</h3>
        <button type="button" data-action="createSystem" title="Create System"><i class="fas fa-plus"></i></button>
      </div>
      <ul class="admin-system-list">
        {{#each systems}}
          <li class="{{#if selected}}active{{/if}}">
            <button type="button" class="system-link" data-action="selectSystem" data-system-id="{{id}}">{{name}}</button>
            <button type="button" data-action="deleteSystem" data-system-id="{{id}}" title="Delete"><i class="fas fa-trash"></i></button>
          </li>
        {{else}}
          <li class="empty">No systems created.</li>
        {{/each}}
      </ul>
    </aside>

    <main class="admin-main">
      {{#if (eq activeTab 'systems')}}
        <section class="admin-panel">
          {{#if hasSystem}}
            <h3>Crafting System</h3>
            <div class="system-meta-grid">
              <div class="form-group span-2">
                <label>Name</label>
                <input type="text" name="systemName" value="{{selectedSystem.name}}" />
              </div>
              <div class="form-group span-2">
                <label>Description</label>
                <textarea name="systemDescription" rows="4">{{selectedSystem.description}}</textarea>
              </div>
              <div class="form-group span-2">
                <label class="checkbox-label"><input type="checkbox" name="systemAdvancedEnabled" data-action="toggleAdvancedOptions" {{#if selectedSystem.advancedOptionsEnabled}}checked{{/if}} /> Show advanced options</label>
                <p class="hint">Advanced options let you configure categories, item tags, essence definitions, complex recipe behavior, and macro-driven crafting logic.</p>
              </div>
            </div>
            <div class="inline-actions">
              <button type="button" data-action="saveSystemDetails"><i class="fas fa-save"></i> Save Details</button>
            </div>

            {{#if selectedSystem.advancedOptionsEnabled}}
            <div class="feature-card-stack">
              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Recipe Categories</h4>
                    <p class="hint">Organize and filter recipes by category in admin and crafting views.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="categories" {{#if selectedSystem.enableCategories}}checked{{/if}} /> Enable</label>
                </div>
                {{#if selectedSystem.enableCategories}}
                  <div class="panel-toolbar compact">
                    <input type="text" name="newSystemCategory" placeholder="e.g. Cooking" />
                    <button type="button" data-action="addSystemCategory"><i class="fas fa-plus"></i> Add</button>
                  </div>
                  <div class="token-list">
                    {{#each selectedSystem.categories}}
                      <span class="token">{{this}} <button type="button" data-action="removeSystemCategory" data-category="{{this}}"><i class="fas fa-times"></i></button></span>
                    {{else}}
                      <p class="hint">No categories defined yet.</p>
                    {{/each}}
                  </div>
                {{/if}}
              </section>

              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Item Tags</h4>
                    <p class="hint">Use tags for categorization, sorting, and search in managed items.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="itemTags" {{#if selectedSystem.enableTags}}checked{{/if}} /> Enable</label>
                </div>
                {{#if selectedSystem.enableTags}}
                  <div class="panel-toolbar compact">
                    <input type="text" name="newSystemTag" placeholder="e.g. armour:leather" />
                    <button type="button" data-action="addSystemTag"><i class="fas fa-plus"></i> Add</button>
                  </div>
                  <div class="token-list">
                    {{#each selectedSystem.itemTags}}
                      <span class="token">{{this}} <button type="button" data-action="removeSystemTag" data-tag="{{this}}"><i class="fas fa-times"></i></button></span>
                    {{else}}
                      <p class="hint">No item tags defined yet.</p>
                    {{/each}}
                  </div>
                {{/if}}
              </section>

              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Essences</h4>
                    <p class="hint">Define essence types with descriptions and optional associated managed items.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="essences" {{#if selectedSystem.enableEssences}}checked{{/if}} /> Enable</label>
                </div>
                {{#if selectedSystem.enableEssences}}
                  <div class="panel-toolbar compact">
                    <input type="text" name="newSystemEssenceName" placeholder="Essence name (e.g. Water)" />
                    <input type="text" name="newSystemEssenceDescription" placeholder="Description (optional)" />
                    <select name="newSystemEssenceAssociatedItem">
                      <option value="">No associated item</option>
                      {{#each selectedSystem.managedItemOptions}}
                        <option value="{{id}}">{{name}}</option>
                      {{/each}}
                    </select>
                    <button type="button" data-action="addSystemEssenceDefinition"><i class="fas fa-plus"></i> Add</button>
                  </div>
                  <div class="essence-definition-list">
                    {{#each selectedSystem.essenceDefinitions}}
                      <article class="essence-definition-row">
                        <div class="essence-definition-meta">
                          <strong>{{name}}</strong>
                          <code>{{id}}</code>
                          {{#if description}}<p class="hint">{{description}}</p>{{/if}}
                          {{#if associatedItemName}}
                            <p class="hint">Associated item: {{associatedItemName}}</p>
                          {{/if}}
                        </div>
                        <button type="button" data-action="removeSystemEssenceDefinition" data-essence-id="{{id}}" title="Remove Essence"><i class="fas fa-trash"></i></button>
                      </article>
                    {{else}}
                      <p class="hint">No essence definitions yet.</p>
                    {{/each}}
                  </div>
                {{/if}}
              </section>

              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Complex Recipes</h4>
                    <p class="hint">Allow multiple ingredient sets, multiple result groups, and advanced routing controls.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="complexRecipes" {{#if selectedSystem.enableComplexRecipes}}checked{{/if}} /> Enable</label>
                </div>
              </section>

              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Property Calculation Macros</h4>
                    <p class="hint">Use macros to compute result property updates from crafting context.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="propertyMacros" {{#if selectedSystem.enablePropertyMacros}}checked{{/if}} /> Enable</label>
                </div>
              </section>

              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Crafting Checks</h4>
                    <p class="hint">Run a system-level check macro that returns pass/fail or named outcomes.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="craftingChecks" {{#if selectedSystem.enableCraftingChecks}}checked{{/if}} /> Enable</label>
                </div>
                {{#if selectedSystem.enableCraftingChecks}}
                  <div class="panel-toolbar compact">
                    <select name="craftingCheckMode">
                      <option value="passFail" {{#if (eq selectedSystem.craftingCheckMode 'passFail')}}selected{{/if}}>Pass / Fail</option>
                      <option value="tiered" {{#if (eq selectedSystem.craftingCheckMode 'tiered')}}selected{{/if}}>Tiered Outcomes</option>
                    </select>
                    <select name="craftingCheckMacroUuid">
                      <option value="">No check macro</option>
                      {{#each selectedSystem.availableScriptMacros}}
                        <option value="{{uuid}}" {{#if (eq ../selectedSystem.craftingCheckMacroUuid uuid)}}selected{{/if}}>{{name}}</option>
                      {{/each}}
                    </select>
                    <input type="text" name="craftingCheckOutcomes" value="{{selectedSystem.craftingCheckOutcomesText}}" placeholder="Outcomes (comma separated)" />
                    <button type="button" data-action="saveCraftingCheckConfig"><i class="fas fa-save"></i> Save Check Config</button>
                  </div>
                {{/if}}
              </section>

              <section class="feature-card">
                <div class="feature-card-header">
                  <div>
                    <h4>Outcome Routing</h4>
                    <p class="hint">Map crafting-check outcomes to specific result groups when complex recipes are enabled.</p>
                  </div>
                  <label class="checkbox-label"><input type="checkbox" data-action="toggleFeature" data-feature="outcomeRouting" {{#if selectedSystem.enableOutcomeRouting}}checked{{/if}} /> Enable</label>
                </div>
              </section>
            </div>
            {{else}}
              <p class="hint">Advanced options are disabled for this system.</p>
            {{/if}}
          {{else}}
            <div class="fabricate-empty">
              <i class="fas fa-layer-group"></i>
              <h3>No Crafting System Selected</h3>
              <p>Create a new system to configure categories, tags, essences, and rules.</p>
            </div>
          {{/if}}
        </section>
      {{/if}}

      {{#if (eq activeTab 'items')}}
        <section class="admin-panel">
          <div class="panel-toolbar">
            <input
              type="text"
              placeholder="Search system items..."
              value="{{itemSearch}}"
              data-action="itemSearch"
              name="itemSearch"
            />
          </div>

          {{#if hasSystem}}
            <div class="drop-zone admin-item-drop-zone" data-drop-zone="system-item">
              <i class="fas fa-download"></i>
              Drag items from sidebar/compendiums here to add them to this crafting system.
            </div>

            <div class="system-item-grid">
              {{#each systemItems}}
                <article class="system-item-card">
                  <div class="item-preview">
                    <img src="{{img}}" alt="{{name}}" />
                    <div class="item-replace-drop" data-drop-zone="system-item-replace" data-item-id="{{id}}" data-item-name="{{name}}">
                      <i class="fas fa-exchange-alt"></i>
                      Drop to replace source
                    </div>
                  </div>
                  <div class="item-meta">
                    <h4>{{name}}</h4>
                    {{#if showTags}}
                      <div class="item-tag-list">
                        {{#each tags}}
                          <span class="token">{{this}}</span>
                        {{else}}
                          <span class="hint">No tags</span>
                        {{/each}}
                      </div>
                    {{/if}}
                    {{#if showEssences}}
                      <div class="item-essence-list">
                        {{#each essences}}
                          <span class="token">{{name}} {{quantity}}</span>
                        {{else}}
                          <span class="hint">No essences</span>
                        {{/each}}
                      </div>
                    {{/if}}
                    {{#if sourceUuid}}
                      <code>{{sourceUuid}}</code>
                    {{else}}
                      <span class="placeholder-src">No source UUID</span>
                    {{/if}}
                  </div>
                  <div class="item-actions">
                    <button type="button" data-action="editSystemItem" data-item-id="{{id}}" title="Edit Item">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button type="button" data-action="deleteSystemItem" data-item-id="{{id}}" title="Delete Item">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </article>
              {{else}}
                <div class="fabricate-empty">
                  <i class="fas fa-inbox"></i>
                  <h3>No Managed Items</h3>
                  <p>Drag in world or compendium items to build this system's item library.</p>
                </div>
              {{/each}}
            </div>
          {{else}}
            <div class="fabricate-empty">
              <i class="fas fa-layer-group"></i>
              <h3>No Crafting System Selected</h3>
              <p>Create or select a crafting system to manage items.</p>
            </div>
          {{/if}}
        </section>
      {{/if}}

      {{#if (eq activeTab 'recipes')}}
        <section class="admin-panel">
          <div class="panel-toolbar recipe-toolbar">
            <input
              type="text"
              name="search"
              placeholder="Search recipes..."
              value="{{search}}"
              data-action="search"
            />
            <button type="button" data-action="createRecipe"><i class="fas fa-plus"></i> New Recipe</button>
            <button type="button" data-action="importRecipes"><i class="fas fa-file-import"></i> Import</button>
            <button type="button" data-action="exportRecipes"><i class="fas fa-file-export"></i> Export</button>
          </div>

          {{#if recipes.length}}
            <table class="recipe-table">
              <thead>
                <tr>
                  <th>Recipe</th>
                  <th>Category</th>
                  <th>Type</th>
                  <th>Components</th>
                  <th>Enabled</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each recipes}}
                  <tr class="recipe-row {{#unless enabled}}disabled{{/unless}}" data-recipe-id="{{id}}">
                    <td>
                      <img src="{{img}}" alt="{{name}}" class="recipe-thumb" />
                      <span>{{name}}</span>
                    </td>
                    <td>{{category}}</td>
                    <td>
                      {{#if isSimple}}
                        <span class="badge badge-simple">Simple</span>
                      {{else}}
                        <span class="badge badge-advanced">Advanced</span>
                      {{/if}}
                    </td>
                    <td>
                      {{ingredients.length}} ingredient{{#unless (eq ingredients.length 1)}}s{{/unless}}
                      {{#if catalysts.length}}
                        + {{catalysts.length}} catalyst{{#unless (eq catalysts.length 1)}}s{{/unless}}
                      {{/if}}
                    </td>
                    <td>
                      <input type="checkbox" {{#if enabled}}checked{{/if}} data-action="toggleEnabled" data-recipe-id="{{id}}" />
                    </td>
                    <td>
                      <button type="button" class="btn-icon" data-action="editRecipe" data-recipe-id="{{id}}" title="Edit"><i class="fas fa-edit"></i></button>
                      <button type="button" class="btn-icon" data-action="duplicateRecipe" data-recipe-id="{{id}}" title="Duplicate"><i class="fas fa-copy"></i></button>
                      <button type="button" class="btn-icon btn-danger" data-action="deleteRecipe" data-recipe-id="{{id}}" title="Delete"><i class="fas fa-trash"></i></button>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{else}}
            <div class="fabricate-empty">
              <i class="fas fa-scroll"></i>
              <h3>No Recipes Yet</h3>
              <p>Create recipes for the selected crafting system.</p>
              <button type="button" class="btn-primary" data-action="createRecipe">
                <i class="fas fa-plus"></i> Create Recipe
              </button>
            </div>
          {{/if}}
        </section>
      {{/if}}

      {{#if (eq activeTab 'rules')}}
        <section class="admin-panel">
          <h3>Global Rules</h3>
          <p>Difficulty and advanced system-wide rule editing will live here.</p>
          <p>This first implementation pass focuses on systems, item libraries, and recipe scoping.</p>
        </section>
      {{/if}}
    </main>
  </div>
</div>
