<form class="fabricate-recipe-editor" autocomplete="off">
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item active" data-tab="basic">
      <i class="fas fa-info-circle"></i>
      Basic Info
    </a>
    <a class="item" data-tab="ingredients">
      <i class="fas fa-list"></i>
      Ingredients
    </a>
    <a class="item" data-tab="catalysts">
      <i class="fas fa-tools"></i>
      Catalysts
    </a>
    <a class="item" data-tab="result">
      <i class="fas fa-gift"></i>
      Result
    </a>
    <a class="item" data-tab="process">
      <i class="fas fa-cogs"></i>
      Process
    </a>
  </nav>

  <section class="sheet-body">
    <!-- Basic Info Tab -->
    <div class="tab active" data-group="primary" data-tab="basic">
      <div class="form-group">
        <label for="recipe-name">Recipe Name *</label>
        <input
          type="text"
          id="recipe-name"
          name="name"
          value="{{recipe.name}}"
          required
          placeholder="e.g., Iron Sword"
        />
      </div>

      <div class="form-group">
        <label for="recipe-description">Description</label>
        <textarea
          id="recipe-description"
          name="description"
          rows="3"
          placeholder="Describe what this recipe creates..."
        >{{recipe.description}}</textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="recipe-category">Category</label>
          <input
            type="text"
            id="recipe-category"
            name="category"
            value="{{recipe.category}}"
            list="category-list"
            placeholder="e.g., Blacksmithing"
          />
          <datalist id="category-list">
            {{#each availableCategories}}
            <option value="{{this}}">
            {{/each}}
          </datalist>
        </div>

        <div class="form-group">
          <label for="recipe-img">Icon</label>
          <div class="file-picker-wrapper">
            <input
              type="text"
              id="recipe-img"
              name="img"
              value="{{recipe.img}}"
              placeholder="icons/svg/item-bag.svg"
            />
            <button type="button" class="file-picker" data-action="pickImage" data-target="img">
              <i class="fas fa-file-image"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>
            <input type="checkbox" name="enabled" {{#if recipe.enabled}}checked{{/if}} />
            Recipe Enabled
          </label>
        </div>

        <div class="form-group">
          <label for="recipe-system">Game System</label>
          <select id="recipe-system" name="system">
            <option value="all" {{#if (eq recipe.system "all")}}selected{{/if}}>All Systems</option>
            <option value="dnd5e" {{#if (eq recipe.system "dnd5e")}}selected{{/if}}>D&D 5e</option>
            <option value="pf2e" {{#if (eq recipe.system "pf2e")}}selected{{/if}}>Pathfinder 2e</option>
            <option value="other" {{#if (eq recipe.system "other")}}selected{{/if}}>Other</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Ingredients Tab -->
    <div class="tab" data-group="primary" data-tab="ingredients">
      <div class="tab-header">
        <h3>Required Ingredients</h3>
        <button type="button" class="btn-add" data-action="addIngredient">
          <i class="fas fa-plus"></i>
          Add Ingredient
        </button>
      </div>

      <div class="ingredient-list" data-list="ingredients">
        {{#each recipe.ingredients}}
          {{> ingredientRow this @index}}
        {{else}}
          <p class="empty-message">No ingredients added yet. Click "Add Ingredient" to begin.</p>
        {{/each}}
      </div>
    </div>

    <!-- Catalysts Tab -->
    <div class="tab" data-group="primary" data-tab="catalysts">
      <div class="tab-header">
        <h3>Required Catalysts</h3>
        <p class="hint">Catalysts are not consumed during crafting (e.g., tools, workstations)</p>
        <button type="button" class="btn-add" data-action="addCatalyst">
          <i class="fas fa-plus"></i>
          Add Catalyst
        </button>
      </div>

      <div class="catalyst-list" data-list="catalysts">
        {{#each recipe.catalysts}}
          {{> catalystRow this @index}}
        {{else}}
          <p class="empty-message">No catalysts required.</p>
        {{/each}}
      </div>
    </div>

    <!-- Result Tab -->
    <div class="tab" data-group="primary" data-tab="result">
      <h3>Recipe Output</h3>

      <div class="form-group">
        <label>Output Mode</label>
        <div class="radio-group">
          <label>
            <input type="radio" name="result.isVariable" value="false" {{#unless recipe.result.isVariable}}checked{{/unless}} />
            Simple (fixed output)
          </label>
          <label>
            <input type="radio" name="result.isVariable" value="true" {{#if recipe.result.isVariable}}checked{{/if}} />
            Variable (properties depend on ingredients)
          </label>
        </div>
      </div>

      <div class="result-simple {{#if recipe.result.isVariable}}hidden{{/if}}">
        <div class="form-group">
          <label>Result Item UUID *</label>
          <input
            type="text"
            name="result.itemUuid"
            value="{{recipe.result.itemUuid}}"
            placeholder="Item.xxxxxxxxxx or drag item here"
            data-dtype="String"
          />
        </div>

        <div class="form-group">
          <label>Quantity</label>
          <input
            type="number"
            name="result.quantity"
            value="{{recipe.result.quantity}}"
            min="1"
            data-dtype="Number"
          />
        </div>
      </div>

      <div class="result-variable {{#unless recipe.result.isVariable}}hidden{{/unless}}">
        <div class="form-group">
          <label>Base Item UUID *</label>
          <input
            type="text"
            name="result.baseItemUuid"
            value="{{recipe.result.baseItemUuid}}"
            placeholder="Item.xxxxxxxxxx"
            data-dtype="String"
          />
        </div>

        <div class="form-group">
          <label>Property Formulas</label>
          <p class="hint">Define how item properties are calculated. Example: system.damage = "1d6 + ingredientTier"</p>
          <div class="formula-list">
            <!-- Formula editor placeholder until dynamic controls are implemented -->
            <textarea
              name="result.propertyFormulas"
              rows="4"
              placeholder='{"system.damage": "1d6 + ingredientTier"}'
            >{{json recipe.result.propertyFormulas}}</textarea>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" name="result.transferEffects" {{#if recipe.result.transferEffects}}checked{{/if}} />
          Transfer Active Effects from Ingredients
        </label>

        {{#if recipe.result.transferEffects}}
        <div class="effect-options">
          <label>Merge Strategy</label>
          <select name="result.effectMergeStrategy">
            <option value="stack" {{#if (eq recipe.result.effectMergeStrategy "stack")}}selected{{/if}}>Stack (keep all)</option>
            <option value="override" {{#if (eq recipe.result.effectMergeStrategy "override")}}selected{{/if}}>Override (latest wins)</option>
            <option value="max" {{#if (eq recipe.result.effectMergeStrategy "max")}}selected{{/if}}>Maximum (strongest wins)</option>
            <option value="sum" {{#if (eq recipe.result.effectMergeStrategy "sum")}}selected{{/if}}>Sum (add together)</option>
          </select>
        </div>
        {{/if}}
      </div>
    </div>

    <!-- Process Tab -->
    <div class="tab" data-group="primary" data-tab="process">
      <h3>Crafting Process</h3>

      <div class="form-group">
        <label>Process Type</label>
        <select name="process.type">
          <option value="instant" {{#if (eq recipe.process.type "instant")}}selected{{/if}}>Instant</option>
          <option value="time" {{#if (eq recipe.process.type "time")}}selected{{/if}}>Time-Based</option>
          <option value="skill" {{#if (eq recipe.process.type "skill")}}selected{{/if}}>Skill Check</option>
        </select>
      </div>

      <div class="process-time {{#unless (eq recipe.process.type "time")}}hidden{{/unless}}">
        <div class="form-group">
          <label>Duration (seconds)</label>
          <input
            type="number"
            name="process.duration"
            value="{{recipe.process.duration}}"
            min="0"
            data-dtype="Number"
          />
        </div>
      </div>

      <div class="process-skill {{#unless (eq recipe.process.type "skill")}}hidden{{/unless}}">
        <div class="form-group">
          <label>Skill Name</label>
          <input
            type="text"
            name="process.skill"
            value="{{recipe.process.skill}}"
            placeholder="e.g., smith, craft"
          />
        </div>

        <div class="form-group">
          <label>Difficulty Class</label>
          <input
            type="number"
            name="process.dc"
            value="{{recipe.process.dc}}"
            min="1"
            data-dtype="Number"
          />
        </div>
      </div>
    </div>
  </section>

  <footer class="sheet-footer">
    <button type="button" class="btn-cancel" data-action="cancel">
      <i class="fas fa-times"></i>
      Cancel
    </button>
    <button type="submit" class="btn-save">
      <i class="fas fa-save"></i>
      Save Recipe
    </button>
  </footer>
</form>
